# Backend Environment Variables

# The port the Express/Socket.io server will bind to
PORT=4000

# The MongoDB connection URI (using local docker instance by default)
MONGODB_URI=mongodb://localhost:27017/quiz-builder

# The API Key for Google Gemini (get this from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# The allowed origin for CORS, to accept requests from the frontend
FRONTEND_URL=http://localhost:5173

# The Node Environment
NODE_ENV=development
